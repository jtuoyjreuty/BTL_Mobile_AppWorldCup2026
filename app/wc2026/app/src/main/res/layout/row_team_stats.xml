<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:layout_marginBottom="12dp"
    android:orientation="horizontal">

    <TextView android:id="@+id/tvHang" android:layout_width="24dp" android:layout_height="24dp" android:gravity="center" android:text="1" android:textColor="#FFFFFF" android:textStyle="bold" />
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="10dp" android:layout_weight="1" android:gravity="center_vertical" android:orientation="horizontal">
        <ImageView android:id="@+id/ivLogo" android:layout_width="20dp" android:layout_height="20dp" android:src="@mipmap/ic_launcher" />
        <TextView android:id="@+id/tvTen" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="Team" android:textColor="#000000" />
    </LinearLayout>
    <TextView android:id="@+id/tvP" android:layout_width="20dp" android:layout_height="wrap_content" android:gravity="center" android:text="0" />
    <TextView android:id="@+id/tvW" android:layout_width="20dp" android:layout_height="wrap_content" android:gravity="center" android:text="0" />
    <TextView android:id="@+id/tvD" android:layout_width="20dp" android:layout_height="wrap_content" android:gravity="center" android:text="0" />
    <TextView android:id="@+id/tvL" android:layout_width="20dp" android:layout_height="wrap_content" android:gravity="center" android:text="0" />
    <TextView android:id="@+id/tvGD" android:layout_width="30dp" android:layout_height="wrap_content" android:gravity="center" android:text="0" />
    <TextView android:id="@+id/tvPTS" android:layout_width="30dp" android:layout_height="wrap_content" android:gravity="center" android:text="0" android:textStyle="bold" android:textColor="#000000"/>
</LinearLayout>